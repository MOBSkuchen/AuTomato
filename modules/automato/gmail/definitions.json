{
  "types": [
    {
      "name": "Email",
      "fields": [
        { "name": "subject", "type": { "kind": "string" } },
        { "name": "sender", "type": { "kind": "string" } },
        { "name": "body", "type": { "kind": "string" } }
      ]
    },
    {
      "name": "GmailClient",
      "kind": "struct",
      "sealed": true,
      "fields": []
    }
  ],
  "components": [
    {
      "name": "connect",
      "category": "pure",
      "description": "Initialise a Gmail client from credentials. Emits a sealed handle used by send.",
      "tweaks": [
        {
          "name": "credentials_path",
          "description": "Path to the Gmail OAuth credentials JSON.",
          "type": { "kind": "string" },
          "default": "./gmail.credentials.json"
        },
        {
          "name": "from_address",
          "description": "Default sender address.",
          "type": { "kind": "string" },
          "default": ""
        }
      ],
      "inputs": [],
      "outputs": [
        { "name": "client", "type": { "kind": "custom", "name": "GmailClient" } }
      ],
      "impl": "Connect"
    },
    {
      "name": "send",
      "category": "action",
      "description": "Send an email through the given client.",
      "inputs": [
        { "name": "client", "type": { "kind": "custom", "name": "GmailClient" } },
        { "name": "email", "type": { "kind": "custom", "name": "Email" }, "consumption": "consumed" }
      ],
      "outputs": [
        { "name": "message_id", "type": { "kind": "string" } }
      ],
      "error_type": { "kind": "string" },
      "impl": "Send"
    }
  ]
}
