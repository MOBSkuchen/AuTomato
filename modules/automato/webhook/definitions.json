{
  "types": [
    {
      "name": "HTTPRequest",
      "fields": [
        { "name": "url", "type": { "kind": "string" } },
        { "name": "method", "type": { "kind": "string" } },
        { "name": "body", "type": { "kind": "string" }},
        { "name": "headers", "type": { "kind": "dict", "value": { "kind": "string" } }}
      ]
    },
    {
      "name": "HTTPMethod",
      "kind": "enum",
      "variants": ["GET", "POST", "PUT", "DELETE", "PATCH", "ANY"]
    },
    {
      "name": "HTTPRequestContext",
      "kind": "struct",
      "sealed": true,
      "fields": []
    },
    {
      "name": "HTTPDispatch",
      "kind": "struct",
      "sealed": true,
      "fields": []
    }
  ],
  "components": [
    {
      "name": "on_request",
      "category": "trigger",
      "trigger_style": "callback",
      "dispatch_mode": "none",
      "description": "Standalone HTTP trigger. Starts its own server on the configured address. Use http_dispatch + on_route if you need multiple routes.",
      "tweaks": [
        {
          "name": "address",
          "description": "Host:port the server binds to.",
          "type": { "kind": "string" },
          "default": ":8080"
        },
        {
          "name": "path",
          "description": "URL path to register the handler on.",
          "type": { "kind": "string" },
          "default": "/"
        },
        {
          "name": "method",
          "description": "Accepted HTTP method (ANY matches all methods).",
          "type": { "kind": "custom", "name": "HTTPMethod" },
          "default": "ANY"
        }
      ],
      "inputs": [],
      "outputs": [
        { "name": "request", "type": { "kind": "custom", "name": "HTTPRequest" } },
        { "name": "ctx", "type": { "kind": "custom", "name": "HTTPRequestContext" } }
      ],
      "impl": "OnRequest"
    },
    {
      "name": "on_route",
      "category": "trigger",
      "trigger_style": "callback",
      "dispatch_mode": "required",
      "dispatch_input_name": "dispatch",
      "description": "Handles HTTP requests matching a specific path and method. Wire its `dispatch` input to an http_dispatch node.",
      "tweaks": [
        {
          "name": "path",
          "description": "URL path pattern to register (e.g. /api/users).",
          "type": { "kind": "string" },
          "default": "/"
        },
        {
          "name": "method",
          "description": "Accepted HTTP method.",
          "type": { "kind": "custom", "name": "HTTPMethod" },
          "default": "ANY"
        }
      ],
      "inputs": [
        { "name": "dispatch", "type": { "kind": "custom", "name": "HTTPDispatch" }, "consumption": "consumed" }
      ],
      "outputs": [
        { "name": "request", "type": { "kind": "custom", "name": "HTTPRequest" } },
        { "name": "ctx", "type": { "kind": "custom", "name": "HTTPRequestContext" } }
      ]
    },
    {
      "name": "http_dispatch",
      "category": "dispatch",
      "description": "Creates an HTTP server and dispatches incoming requests to registered route handlers. Wire its `dispatch` output into one or more on_route triggers, then wire exec into it from your origin/trigger.",
      "inputs": [
        {
          "name": "address",
          "type": { "kind": "string" },
          "consumption": "consumed"
        }
      ],
      "outputs": [
        {
          "name": "dispatch",
          "type": { "kind": "custom", "name": "HTTPDispatch" }
        }
      ],
      "impl": "NewHTTPDispatch",
      "dispatch_type": { "kind": "custom", "name": "HTTPDispatch" },
      "run_method": "Run",
      "register_methods": { "on_route": "Register" }
    },
    {
      "name": "respond",
      "category": "return",
      "description": "Writes an HTTP response for the given request context, then ends the workflow.",
      "tweaks": [
        {
          "name": "content_type",
          "description": "Content-Type header value.",
          "type": { "kind": "string" },
          "default": "text/plain; charset=utf-8"
        }
      ],
      "inputs": [
        { "name": "ctx", "type": { "kind": "custom", "name": "HTTPRequestContext" }, "consumption": "consumed" },
        { "name": "status", "type": { "kind": "int" } },
        { "name": "body", "type": { "kind": "string" }, "consumption": "consumed" }
      ],
      "outputs": [],
      "impl": "Respond"
    },
    {
      "name": "respond_json",
      "category": "return",
      "description": "Writes a JSON body with Content-Type application/json and ends the workflow.",
      "inputs": [
        { "name": "ctx", "type": { "kind": "custom", "name": "HTTPRequestContext" }, "consumption": "consumed" },
        { "name": "status", "type": { "kind": "int" } },
        { "name": "body", "type": { "kind": "string" }, "consumption": "consumed" }
      ],
      "outputs": [],
      "impl": "RespondJSON"
    }
  ]
}
